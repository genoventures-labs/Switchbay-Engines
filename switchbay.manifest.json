{
  "name": "switchbay-engine-bay",
  "version": "0.1.0",
  "description": "Engine parts and templates for Switchbay: a terminal-first AI coding workbench.",
  "root": "./",
  "engines": [
    {
      "id": "gumops",
      "displayName": "GumOps Engine",
      "path": "engines/Python/Gumroad/",
      "type": "python",
      "manifest": "engines/Python/Gumroad/gumops.engine.json",
      "entrypoints": [
        "engines/Python/Gumroad/gumops_runner.py",
        "engines/Python/Gumroad/gumsdk.py",
        "engines/Python/Gumroad/working_memory/working_memory.py"
      ],
      "skills": [
        "engines/Python/Gumroad/skills/gumroad-seller-ops.skill.md",
        "engines/Python/Gumroad/skills/gumroad-analytics.skill.md",
        "engines/Python/Gumroad/skills/gumroad-memory-ops.skill.md"
      ]
    },
    {
      "id": "facebook",
      "displayName": "Facebook",
      "path": "engines/Python/Facebook/",
      "type": "python",
      "entrypoints": [
        "engines/Python/Facebook/fbgent.py",
        "engines/Python/Facebook/fb_api.py"
      ]
    },
    {
      "id": "file-helper",
      "displayName": "File Helper",
      "path": "engines/Python/FileHelper/",
      "type": "python",
      "entrypoints": [
        "engines/Python/FileHelper/file_helper.py"
      ]
    },
    {
      "id": "ruby-text-helper",
      "displayName": "Text Helper",
      "path": "engines/Ruby/",
      "type": "ruby",
      "entrypoints": [
        "engines/Ruby/text_helper.rb"
      ]
    },
    {
      "id": "macos-agent",
      "displayName": "MacOS Agent",
      "path": "engines/Python/MacOS/",
      "type": "python",
      "entrypoints": [
        "engines/Python/MacOS/macos_agent.py",
        "engines/Python/MacOS/finder_safe.py"
      ]
    },
    {
      "id": "workspace-scout",
      "displayName": "Workspace Scout",
      "path": "engines/Node/WorkspaceScout/",
      "type": "node",
      "entrypoints": [
        "engines/Node/WorkspaceScout/workspace_scout.mjs"
      ]
    },
    {
      "id": "web-search",
      "displayName": "Web Search Engine",
      "path": "engines/Python/WebSearch/",
      "type": "python",
      "entrypoints": [
        "engines/Python/WebSearch/web_search.py"
      ]
    },
    {
      "id": "pinata",
      "displayName": "PINATA Workbench",
      "path": "engines/Python/PINATA/",
      "type": "python",
      "manifest": "engines/Python/PINATA/pinata.engine.json",
      "entrypoints": [
        "engines/Python/PINATA/pinata.py"
      ],
      "skills": [
        "engines/Python/PINATA/skills/pinata-research.skill.md"
      ]
    }
  ],
  "files": [
    "README.md",
    "engines/Python/Gumroad/gumops.engine.json",
    "engines/Python/Gumroad/gumops_runner.py",
    "engines/Python/Gumroad/gumgent.py",
    "engines/Python/Gumroad/gumsdk.py",
    "engines/Python/Gumroad/lms_sdk.py",
    "engines/Python/Gumroad/shopgent.py",
    "engines/Python/Gumroad/working_memory/working_memory.py",
    "engines/Python/Gumroad/skills/gumroad-seller-ops.skill.md",
    "engines/Python/Gumroad/skills/gumroad-analytics.skill.md",
    "engines/Python/Gumroad/skills/gumroad-memory-ops.skill.md",
    "engines/Python/Facebook/fbgent.py",
    "engines/Python/Facebook/fb_api.py",
    "engines/Ruby/text_helper.rb",
    "engines/Python/FileHelper/file_helper.py",
    "engines/Python/MacOS/macos_agent.py",
    "engines/Python/MacOS/finder_safe.py",
    "engines/Node/WorkspaceScout/workspace_scout.mjs",
    "engines/Node/WorkspaceScout/workspace_scout.engine.json",
    "engines/Python/WebSearch/web_search.py",
    "engines/Python/WebSearch/web_search.engine.json",
    "engines/Python/PINATA/pinata.py",
    "engines/Python/PINATA/pinata.engine.json",
    "engines/Python/PINATA/skills/pinata-research.skill.md"
  ]
}
